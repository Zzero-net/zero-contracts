# ZeroVault Deployment Configuration
# Copy to .env and fill in values before deploying.

# --- Deployer ---
# Private key of the deployer account (needs ETH for gas)
DEPLOYER_PRIVATE_KEY=0x...

# --- Trinity Validator Addresses ---
# These are the Ethereum addresses (derived from ECDSA keys) of the 3 Trinity Validators.
# Each validator runs the zero-bridge service and signs release operations.
GUARDIAN_1=0x...
GUARDIAN_2=0x...
GUARDIAN_3=0x...

# --- Admin ---
# Admin address controls: unpause, guardian rotation, token management.
# For testnet, can be the deployer. For mainnet, MUST be a multisig or TimelockController.
ADMIN_ADDRESS=0x...

# --- Base Sepolia ---
BASE_SEPOLIA_RPC=https://sepolia.base.org
# USDC on Base Sepolia (Circle's test USDC — may need to be deployed or use faucet)
BASE_SEPOLIA_USDC=0x...

# --- Arbitrum Sepolia ---
ARBITRUM_SEPOLIA_RPC=https://sepolia-rollup.arbitrum.io/rpc
# USDT on Arbitrum Sepolia
ARBITRUM_SEPOLIA_USDT=0x...
